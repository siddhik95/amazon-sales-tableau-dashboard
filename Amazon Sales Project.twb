      <aliases enabled='yes' />
      <column datatype='real' default-format='p0.00%' name='[Calculation2]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([product_id]) / TOTAL(COUNT([product_id]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Return Flag' datatype='integer' name='[Calculation_0023092374097920]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [is_returned] = TRUE THEN 1 ELSE 0 END' />
      </column>
      <column caption='Return Rate' datatype='real' name='[Calculation_0023092374282241]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0023092374097920]) / COUNT([product_id])' />
      </column>
      <column caption='Average Order Value' datatype='real' name='[Calculation_0023092374343682]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([final_price]) / COUNT([product_id])' />
      </column>
      <column caption='Shipping Category' datatype='string' name='[Calculation_0023092374413315]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [shipping_time_days] &lt;= 2 THEN &quot;Fast&quot;&#13;&#10;ELSEIF [shipping_time_days] &lt;=5 THEN &quot;Medium&quot;&#13;&#10;ELSE &quot;Slow&quot;&#13;&#10;END' />
      </column>
      <column caption='Price Bucket' datatype='string' name='[Calculation_0023092374482948]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [final_price] &lt; 1000 THEN &quot;Low&quot;&#13;&#10;ELSEIF [final_price] &lt; 10000 THEN &quot;Medium&quot;&#13;&#10;ELSE &quot;High&quot;&#13;&#10;END' />
      </column>
      <column caption='Purchase Month' datatype='string' name='[Calculation_0023092374585349]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATENAME(&apos;month&apos;,[purchase_date])' />
      </column>
      <column caption='Purchase Year' datatype='integer' name='[Calculation_0023092374724614]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='YEAR([purchase_date])' />
      </column>
      <column caption='Total Revenue' datatype='real' name='[Calculation_0023092378697735]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([final_price])' />
      </column>
      <column caption='Total Customers' datatype='integer' name='[Calculation_0781207016189952]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([user_id])' />
      </column>
      <column caption='Delivered Orders' datatype='integer' name='[Calculation_0781207017689089]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(&#13;&#10;IF [delivery_status] = &quot;Delivered&quot;&#13;&#10;THEN [product_id]&#13;&#10;END)' />
      </column>
      <column caption='Delayed Orders' datatype='integer' name='[Calculation_0781207018389506]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(&#13;&#10;IF [delivery_status] = &quot;Delayed&quot;&#13;&#10;THEN [product_id]&#13;&#10;END)' />
      </column>
      <column caption='Returned Orders' datatype='integer' name='[Calculation_0781207019159555]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(&#13;&#10;IF [delivery_status] = &quot;Returned&quot;&#13;&#10;THEN [product_id]&#13;&#10;END)' />
      </column>
      <column caption='Avg Delivery Time' datatype='real' datatype-customized='true' name='[Calculation_0781207019798532]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([shipping_time_days])' />
      </column>
      <column caption='Calculation1' datatype='integer' name='[Calculation_1438439316975616]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1' />
      </column>
