          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='amazon_ecommerce_1M' name='federated.0rcwdjq0kffh1c1fgaw4d0hj27d1' />
          </datasources>
          <datasource-dependencies datasource='federated.0rcwdjq0kffh1c1fgaw4d0hj27d1'>
            <column caption='Return Flag' datatype='integer' name='[Calculation_0023092374097920]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [is_returned] = TRUE THEN 1 ELSE 0 END' />
            </column>
            <column caption='Return Rate' datatype='real' name='[Calculation_0023092374282241]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Calculation_0023092374097920]) / COUNT([product_id])' />
            </column>
            <column caption='Purchase Month' datatype='string' name='[Calculation_0023092374585349]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='DATENAME(&apos;month&apos;,[purchase_date])' />
            </column>
            <column caption='Category' datatype='string' name='[category]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_0023092374282241]' derivation='User' name='[cum:usr:Calculation_0023092374282241:qk]' pivot='key' type='quantitative'>
              <table-calc aggregation='Sum' ordering-type='Rows' type='CumTotal' />
            </column-instance>
            <column caption='Returned' datatype='boolean' name='[is_returned]' role='dimension' type='nominal' />
            <column caption='Payment Method' datatype='string' name='[payment_method]' role='dimension' type='nominal' />
            <column caption='Product Id' datatype='string' name='[product_id]' role='dimension' type='nominal' />
            <column caption='Purchase Date' datatype='date' name='[purchase_date]' role='dimension' type='ordinal' />
